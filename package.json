{
  "name": "pokemon-researcher",
  "version": "1.0.0",
  "description": "A desktop application for researching Pokemon using Bulbapedia",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"wait-on http://localhost:3001/health && electron .\"",
    "server": "node src/server/server.js",
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": ["pokemon", "bulbapedia", "electron", "research"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.1"
  }
}
